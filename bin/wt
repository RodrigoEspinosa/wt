#!/usr/bin/env bash
set -euo pipefail

VERSION="0.6.1"
PROG="wt"

# --- helpers ----------------------------------------------------------------

die() { printf '%s: %s\n' "$PROG" "$1" >&2; exit 1; }

# Run "$@" while showing a spinner on stderr, so slow git operations don't look
# like a freeze. Falls back to a plain run when stderr isn't a terminal (scripts,
# CI, tests). Returns the command's exit status; its output is captured and
# replayed afterwards so it never collides with the spinner line.
spin() {
  local msg="$1"; shift
  if [ ! -t 2 ]; then
    # No terminal (scripts, CI, tests): leave a breadcrumb and run plainly. The
    # command's own output goes to stderr so stdout stays reserved for results.
    printf '%s: %s...\n' "$PROG" "$msg" >&2
    "$@" >&2
    return $?
  fi

  local out
  out="$(mktemp)"
  "$@" >"$out" 2>&1 &
  local pid=$! i=0 rc=0
  local frames=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
  trap 'kill "$pid" 2>/dev/null; printf "\r\033[K\033[?25h" >&2' INT TERM
  printf '\033[?25l' >&2
  while kill -0 "$pid" 2>/dev/null; do
    printf '\r%s %s' "${frames[i++ % ${#frames[@]}]}" "$msg" >&2
    sleep 0.08
  done
  wait "$pid" || rc=$?
  printf '\r\033[K\033[?25h' >&2
  trap - INT TERM
  [ -s "$out" ] && cat "$out" >&2
  rm -f "$out"
  return $rc
}

usage() {
  cat <<EOF
Usage: $PROG [<branch> [<start-point>]]
       $PROG pr <number>
       $PROG clean [--prune] [--yes]
       $PROG -d <branch>
       $PROG -l
       $PROG init <shell>

Git worktree manager powered by fzf.

With no arguments, launches fzf to fuzzy-pick a worktree. In the picker,
enter switches, ctrl-n creates a worktree from the typed name, and
ctrl-d/del deletes the highlighted one.
With <branch>, switches to that worktree — creating it if it doesn't exist.
A new branch starts at <start-point> if given (commit, branch, or tag).

Commands:
  pr <number>   Check out a GitHub pull request in a new worktree
  clean         Pick and remove merged or stale worktrees (fzf multi-select)
                --prune fetches/prunes remotes first; --yes removes all
                candidates without prompting
  init <shell>  Print shell integration (bash, zsh, fish)

Options:
  -d <branch>   Remove the worktree for <branch> (deletes the local branch
                too if it is fully merged)
  -l            List worktrees (no fzf)
  -h            Show this help
  -v            Show version

Setup:
  Add to your shell rc file:
    eval "\$($PROG init zsh)"    # or bash, fish

Hooks:
  Drop a .wtconfig file at the repo root to prep new worktrees automatically:
    copy = .env                # copy file/dir from the primary worktree
    link = node_modules        # symlink from the primary worktree
    postCreate = pnpm install  # shell command run inside the new worktree
  copy/link/postCreate may each appear multiple times. Set WT_NO_HOOKS=1 to skip.

  A baseDir = <path> line in .wtconfig sets the worktree parent directory per
  repo (overridden by WT_BASE_DIR). Relative paths resolve against the repo root.

Environment:
  WT_BASE_DIR   Parent directory for worktrees (default: <repo>/_worktrees)
  WT_NO_HOOKS   When set, skip .wtconfig copy/link/postCreate hooks
EOF
  exit 0
}

# --- ensure we're in a git repo ---------------------------------------------

ensure_git() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"
}

# --- resolve paths ----------------------------------------------------------

repo_root() {
  local toplevel
  toplevel="$(git rev-parse --show-toplevel 2>/dev/null)" || true
  if [ -n "$toplevel" ]; then
    echo "$toplevel"
  else
    git rev-parse --git-dir
  fi
}

worktree_base() {
  # WT_BASE_DIR wins, then a baseDir key in .wtconfig, then the default.
  if [ -n "${WT_BASE_DIR:-}" ]; then
    echo "$WT_BASE_DIR"
    return
  fi

  local configured
  configured="$(config_get baseDir | head -n1)"
  if [ -n "$configured" ]; then
    case "$configured" in
      /*)  echo "$configured" ;;                          # absolute
      \~*) echo "$HOME${configured#\~}" ;;                # home-relative
      *)   echo "$(repo_root)/$configured" ;;             # relative to repo root
    esac
    return
  fi

  echo "$(repo_root)/_worktrees"
}

# Convert a branch name to a flat directory name (e.g. rec/foo -> rec-foo).
safe_dirname() {
  printf '%s' "$1" | tr '/' '-'
}

# The primary (main) working tree — the first entry git reports. This is the
# source of truth for .wtconfig and the files copied/linked into new worktrees.
primary_worktree() {
  git worktree list --porcelain | awk '/^worktree / { print substr($0, 10); exit }'
}

# --- config & hooks ---------------------------------------------------------

# Path to the .wtconfig file in the primary worktree, if one exists.
config_path() {
  local root
  root="$(primary_worktree)"
  [ -n "$root" ] && [ -f "$root/.wtconfig" ] && echo "$root/.wtconfig"
}

# Print every value for <key> in .wtconfig, one per line. Lines look like
# "key = value"; blank lines and those starting with # are ignored.
config_get() {
  local key="$1" file
  file="$(config_path)"
  [ -z "$file" ] && return 0
  sed -n "s/^[[:space:]]*${key}[[:space:]]*=[[:space:]]*//p" "$file" | sed 's/[[:space:]]*$//'
}

# Run the .wtconfig hooks for a freshly created worktree. All output goes to
# stderr so stdout stays reserved for the worktree path the shell wrapper cd's
# into. Failures are reported but never abort the switch.
run_hooks() {
  local branch="$1" wt_path="$2"
  [ -n "${WT_NO_HOOKS:-}" ] && return 0

  local src
  src="$(primary_worktree)"
  [ -z "$src" ] && return 0

  local f
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if [ -e "$src/$f" ]; then
      mkdir -p "$(dirname "$wt_path/$f")"
      cp -R "$src/$f" "$wt_path/$f" && printf '%s: copied %s\n' "$PROG" "$f" >&2
    else
      printf '%s: skip copy %s (not in primary worktree)\n' "$PROG" "$f" >&2
    fi
  done < <(config_get copy)

  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if [ -e "$src/$f" ]; then
      mkdir -p "$(dirname "$wt_path/$f")"
      ln -s "$src/$f" "$wt_path/$f" && printf '%s: linked %s\n' "$PROG" "$f" >&2
    else
      printf '%s: skip link %s (not in primary worktree)\n' "$PROG" "$f" >&2
    fi
  done < <(config_get link)

  local cmd
  while IFS= read -r cmd; do
    [ -z "$cmd" ] && continue
    printf '%s: postCreate: %s\n' "$PROG" "$cmd" >&2
    if ! ( cd "$wt_path" && WT_BRANCH="$branch" WT_PATH="$wt_path" WT_SOURCE="$src" \
             bash -c "$cmd" ) >&2; then
      printf '%s: postCreate hook failed (continuing)\n' "$PROG" >&2
    fi
  done < <(config_get postCreate)
}

# --- core functions ---------------------------------------------------------

list_worktrees() {
  local target="${1:-}"
  git worktree list --porcelain | TARGET="$target" awk '
    BEGIN { target = ENVIRON["TARGET"] }
    /^worktree / { path = substr($0, 10) }
    /^branch /   {
      branch = substr($0, 8);
      sub("refs/heads/", "", branch);
      if (target != "") {
        if (branch == target) { print path; exit }
      } else {
        print branch "\t" path
      }
    }
    /^detached/  {
      if (target != "") {
        if (target == "(detached)" && path != "") { print path; exit }
      } else if (path != "") {
        print "(detached)\t" path
      }
    }
  '
}

# Decorate worktrees for display. Emits, per worktree, four tab-separated
# fields: "<flags>\t<branch>\t<path>\t<ahead/behind>".
#   flags  two markers — '*' for the worktree you're currently in, '!' if it
#          has uncommitted changes (tracked or untracked).
#   a/b    "↑N" commits ahead / "↓N" behind its upstream, when it has one.
# The branch and path stay in their own clean fields so callers can parse them.
# Decorate a single worktree (<branch> <path>) and print its four-field row.
# Each call shells out to git status + rev-list, so annotate_worktrees runs many
# of these in parallel. WT_CUR_TOP names the worktree we're currently in.
annotate_one() {
  local branch="$1" path="$2"
  local cur=" " dirty=" " ab="" counts behind ahead
  [ "$path" = "${WT_CUR_TOP:-}" ] && cur="*"
  [ -n "$(git -C "$path" status --porcelain 2>/dev/null || true)" ] && dirty="!"

  counts="$(git -C "$path" rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null || true)"
  if [ -n "$counts" ]; then
    behind="${counts%%	*}"
    ahead="${counts##*	}"
    [ "${ahead:-0}" != 0 ] && ab="$ab ↑$ahead"
    [ "${behind:-0}" != 0 ] && ab="$ab ↓$behind"
  fi

  printf '%s%s\t%s\t%s\t%s\n' "$cur" "$dirty" "$branch" "$path" "$ab"
}

# Decorate every worktree for display, computing the per-worktree git lookups in
# parallel and streaming rows to stdout as they finish (fzf renders them live).
# Output order is non-deterministic — fzf sorts on match anyway. See annotate_one
# for the field layout.
annotate_worktrees() {
  local list jobs
  list="$(list_worktrees)"
  [ -z "$list" ] && return 0

  jobs="$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 4)"
  export WT_CUR_TOP
  WT_CUR_TOP="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  export -f annotate_one

  # Feed branch and path as separate NUL-delimited tokens (-0 -n2) so values with
  # spaces survive and xargs never reinterprets the tab/field separators.
  printf '%s\n' "$list" | tr '\t\n' '\0\0' \
    | xargs -0 -n2 -P "$jobs" bash -c 'annotate_one "$@"' _
}

pick_worktree() {
  local query="${1:-}"
  local selection

  command -v fzf >/dev/null 2>&1 || die "fzf is required for the interactive picker (https://github.com/junegunn/fzf)"

  selection=$(
    annotate_worktrees |
    fzf --delimiter='\t' \
        --height='~50%' --layout=reverse \
        --with-nth=1,2,4 \
        --prompt="worktree> " \
        --query="$query" \
        --print-query \
        --header="enter: cd · ctrl-n: new · ctrl-d/del: delete" \
        --expect=ctrl-d,del,ctrl-n \
        --preview="echo {3}; echo; git -C {3} -c color.status=always status -sb 2>/dev/null; echo; git -C {3} log --oneline -10 2>/dev/null || echo 'no commits'" \
        --preview-window=right:60%:wrap
  ) || true

  # With --print-query and --expect, fzf prints up to three lines: the typed
  # query, the pressed key (empty for plain enter), then the selected row.
  # set -e is suppressed for the group because it precedes a "|| true".
  local query_line key item
  { IFS= read -r query_line; IFS= read -r key; IFS= read -r item; } <<< "$selection" || true

  # ctrl-n: create (or switch to) a worktree named by the typed query.
  if [ "$key" = "ctrl-n" ]; then
    [ -n "$query_line" ] || return 0
    goto_worktree "$query_line"
    return 0
  fi

  # No row selected (empty list or Esc) — nothing to do.
  [ -z "$item" ] && return 0

  local branch wt_path
  branch="$(printf '%s' "$item" | cut -f2)"
  wt_path="$(printf '%s' "$item" | cut -f3)"

  if [ "$key" = "ctrl-d" ] || [ "$key" = "del" ]; then
    remove_worktree "$branch"
    return 0
  fi

  if [ -d "$wt_path" ]; then
    echo "$wt_path"
  else
    die "worktree path not found: $wt_path"
  fi
}

create_worktree() {
  local branch="$1"
  local start_point="${2:-}"
  local base
  base="$(worktree_base)"
  local wt_path
  wt_path="$base/$(safe_dirname "$branch")"

  if [ -d "$wt_path" ]; then
    # The dir already exists. Guard against safe_dirname collisions: "a/b" and
    # "a-b" both flatten to "a-b". If it's a worktree for a *different* branch,
    # refuse rather than silently switching to the wrong tree; otherwise treat
    # the call as idempotent and just hand back the path.
    local occupant
    occupant="$(git -C "$wt_path" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
    if [ -n "$occupant" ] && [ "$occupant" != "$branch" ]; then
      die "worktree dir already used by branch '$occupant': $wt_path (rename to avoid the slash/dash collision, or set WT_BASE_DIR)"
    fi
    echo "$wt_path"
    return 0
  fi

  if git show-ref --verify --quiet "refs/heads/$branch"; then
    spin "Creating worktree $branch" git worktree add "$wt_path" "$branch"
  elif [ -n "$start_point" ]; then
    spin "Creating worktree $branch" git worktree add -b "$branch" "$wt_path" "$start_point"
  else
    spin "Creating worktree $branch" git worktree add -b "$branch" "$wt_path"
  fi

  run_hooks "$branch" "$wt_path"
  echo "$wt_path"
}

get_worktree_path() {
  local branch="$1"
  list_worktrees "$branch"
}

# Get or create a worktree for <branch>, print its path
goto_worktree() {
  local branch="$1"
  local start_point="${2:-}"
  local wt_path

  # Check if a worktree for this branch already exists
  wt_path=$(get_worktree_path "$branch")

  if [ -n "$wt_path" ]; then
    echo "$wt_path"
  else
    create_worktree "$branch" "$start_point"
  fi
}

remove_worktree() {
  local branch="$1"
  local wt_path

  wt_path=$(get_worktree_path "$branch")

  if [ -z "$wt_path" ]; then
    die "no worktree found for branch: $branch"
  fi

  # Refuse to remove a worktree with uncommitted *tracked* changes. Untracked
  # files are expected (postCreate hooks build node_modules etc.), so we force
  # past those — but never past unsaved edits to tracked files.
  local tracked_dirty
  tracked_dirty="$(git -C "$wt_path" status --porcelain --untracked-files=no 2>/dev/null || true)"
  if [ -n "$tracked_dirty" ]; then
    die "worktree has uncommitted changes: $wt_path (stash/commit them, or run: git worktree remove --force \"$wt_path\")"
  fi

  spin "Removing worktree $branch" git worktree remove --force "$wt_path"
  printf 'Removed worktree: %s (%s)\n' "$branch" "$wt_path" >&2

  if [ "$branch" != "(detached)" ]; then
    if git branch -d "$branch" >/dev/null 2>&1; then
      printf 'Deleted branch: %s\n' "$branch" >&2
    else
      printf 'Kept branch %s (not fully merged; delete with: git branch -D %s)\n' "$branch" "$branch" >&2
    fi
  fi
}

# --- pull requests ----------------------------------------------------------

# Pick the remote to fetch PRs from: prefer "origin", else the first remote.
default_remote() {
  if git remote | grep -qx origin; then
    echo origin
  else
    git remote | head -1
  fi
}

# Check out GitHub PR #<n> in a worktree, printing its path.
pr_worktree() {
  local n="$1"
  [ -n "$n" ] || die "usage: $PROG pr <number>"
  case "$n" in ''|*[!0-9]*) die "invalid PR number: $n" ;; esac

  local remote
  remote="$(default_remote)"
  [ -n "$remote" ] || die "no git remote configured"

  # Use gh for a human-friendly branch name when available; otherwise pr-<n>.
  local branch=""
  if command -v gh >/dev/null 2>&1; then
    branch="$(gh pr view "$n" --json headRefName -q .headRefName 2>/dev/null || true)"
  fi
  [ -n "$branch" ] || branch="pr-$n"

  # Already checked out? Just go there.
  local existing
  existing="$(get_worktree_path "$branch")"
  if [ -n "$existing" ]; then
    echo "$existing"
    return 0
  fi

  spin "Fetching PR #$n from $remote" git fetch -q "$remote" "refs/pull/$n/head:$branch" \
    || die "could not fetch PR #$n from $remote"

  local base wt_path
  base="$(worktree_base)"
  wt_path="$base/$(safe_dirname "$branch")"
  spin "Creating worktree $branch" git worktree add "$wt_path" "$branch"
  run_hooks "$branch" "$wt_path"
  echo "$wt_path"
}

# --- clean ------------------------------------------------------------------

# The repo's default branch — used to decide what counts as "merged".
default_branch() {
  local d
  d="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@')"
  if [ -n "$d" ]; then echo "$d"; return; fi
  local c
  for c in main master trunk; do
    if git show-ref --verify --quiet "refs/heads/$c"; then echo "$c"; return; fi
  done
  git -C "$(primary_worktree)" symbolic-ref --quiet --short HEAD 2>/dev/null || true
}

# Print "branch<TAB>path<TAB>reason" for each worktree branch that is merged
# into the default branch or whose upstream has been deleted ("gone").
clean_candidates() {
  local def merged_list gone_list cur_top
  def="$(default_branch)"
  merged_list="$(git branch --merged "$def" --format='%(refname:short)' 2>/dev/null || true)"
  gone_list="$(git for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads \
                 | awk '$2 == "[gone]" { print $1 }')"
  cur_top="$(git rev-parse --show-toplevel 2>/dev/null || true)"

  list_worktrees | while IFS=$'\t' read -r branch path; do
    [ "$branch" = "(detached)" ] && continue
    [ "$branch" = "$def" ] && continue
    [ "$path" = "$cur_top" ] && continue

    local reason=""
    if printf '%s\n' "$merged_list" | grep -qx "$branch"; then
      reason="merged into $def"
    fi
    if printf '%s\n' "$gone_list" | grep -qx "$branch"; then
      if [ -n "$reason" ]; then reason="$reason, upstream gone"; else reason="upstream gone"; fi
    fi

    if [ -n "$reason" ]; then
      printf '%s\t%s\t%s\n' "$branch" "$path" "$reason"
    fi
  done
}

clean_worktrees() {
  local do_prune="" assume_yes=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --prune)            do_prune=1 ;;
      -y|--yes|--all)     assume_yes=1 ;;
      *)                  die "unknown clean option: $1 (use --prune, --yes)" ;;
    esac
    shift
  done

  # --prune refreshes remote-tracking refs first so "upstream gone" is accurate.
  if [ -n "$do_prune" ]; then
    printf '%s: fetching and pruning remotes...\n' "$PROG" >&2
    git fetch --all --prune -q >&2 || printf '%s: prune fetch failed (continuing)\n' "$PROG" >&2
  fi

  local candidates
  candidates="$(clean_candidates)"

  if [ -z "$candidates" ]; then
    printf '%s: nothing to clean — no merged or stale worktrees\n' "$PROG" >&2
    return 0
  fi

  # --yes removes every candidate without prompting (handy for scripts/CI).
  if [ -n "$assume_yes" ]; then
    printf '%s\n' "$candidates" | while IFS=$'\t' read -r branch _ _; do
      [ -z "$branch" ] && continue
      remove_worktree "$branch" || true
    done
    return 0
  fi

  if ! command -v fzf >/dev/null 2>&1; then
    printf '%s: merged or stale worktrees (install fzf to select, or use -d):\n' "$PROG" >&2
    printf '%s\n' "$candidates" | awk -F'\t' '{ printf "  %-30s %s\n", $1, $3 }' >&2
    return 0
  fi

  local selection
  selection=$(
    printf '%s\n' "$candidates" |
    fzf --multi --delimiter='\t' --with-nth=1,3 \
        --height='~50%' --layout=reverse \
        --prompt="clean> " \
        --header="tab: mark · enter: remove · esc: cancel" \
        --preview="echo {2}; echo; git -C {2} log --oneline -10 2>/dev/null || echo 'no commits'" \
        --preview-window=right:60%:wrap
  ) || return 0

  [ -z "$selection" ] && return 0

  printf '%s\n' "$selection" | while IFS=$'\t' read -r branch _ _; do
    [ -z "$branch" ] && continue
    remove_worktree "$branch" || true
  done
}

# --- shell integration ------------------------------------------------------

shell_init() {
  local shell="${1:-}"
  case "$shell" in
    bash)
      cat <<'SHELL'
wt() {
  if [ "$1" = "init" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ] || [ "$1" = "-v" ] || [ "$1" = "--version" ]; then
    command wt "$@"
    return
  fi
  local result
  result="$(command wt "$@")" || return $?
  if [ -d "$result" ]; then
    cd "$result" || return
  elif [ -n "$result" ]; then
    printf '%s\n' "$result"
  fi
}

_wt() {
  local cur prev
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  case "$prev" in
    -d)
      local worktrees
      worktrees="$(git worktree list --porcelain 2>/dev/null | awk '/^branch / { b = substr($0, 8); sub("refs/heads/", "", b); print b }')"
      COMPREPLY=($(compgen -W "$worktrees" -- "$cur"))
      return
      ;;
    init)
      COMPREPLY=($(compgen -W "bash zsh fish" -- "$cur"))
      return
      ;;
  esac

  if [[ "$cur" == -* ]]; then
    COMPREPLY=($(compgen -W "-d -l -h -v" -- "$cur"))
  else
    local branches
    branches="$(git branch --format='%(refname:short)' 2>/dev/null)"
    COMPREPLY=($(compgen -W "$branches pr clean" -- "$cur"))
  fi
}
complete -F _wt wt
SHELL
      ;;
    zsh)
      cat <<'SHELL'
wt() {
  if [ "$1" = "init" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ] || [ "$1" = "-v" ] || [ "$1" = "--version" ]; then
    command wt "$@"
    return
  fi
  local result
  result="$(command wt "$@")" || return $?
  if [ -d "$result" ]; then
    cd "$result" || return
  elif [ -n "$result" ]; then
    printf '%s\n' "$result"
  fi
}

_wt() {
  local -a branches worktrees shells opts
  shells=(bash zsh fish)
  opts=(-d -l -h -v)

  _arguments -s \
    '(-d -l -h -v)1:command:(init pr clean)' \
    '-d[Remove worktree]:branch:->worktrees' \
    '-l[List worktrees]' \
    '-h[Show help]' \
    '-v[Show version]' \
    '*:branch:->branches' \
    && return

  case "$state" in
    worktrees)
      worktrees=(${(f)"$(git worktree list --porcelain 2>/dev/null | awk '/^branch / { b = substr($0, 8); sub("refs/heads/", "", b); print b }')"})
      _describe 'worktree branch' worktrees
      ;;
    branches)
      if [[ "${words[2]}" == "init" ]]; then
        _describe 'shell' shells
      else
        branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
        _describe 'branch' branches
      fi
      ;;
  esac
}
compdef _wt wt
SHELL
      ;;
    fish)
      cat <<'SHELL'
function wt
  if test (count $argv) -gt 0
    switch $argv[1]
      case init -h --help -v --version
        command wt $argv
        return
    end
  end
  set -l result (command wt $argv)
  or return $status
  if test -d "$result"
    cd "$result"
  else if test -n "$result"
    echo "$result"
  end
end

# Clear any existing completions for wt
complete -e -c wt

# Flags
complete -c wt -s d -x -d 'Remove worktree' -a '(git worktree list --porcelain 2>/dev/null | string match -r "^branch refs/heads/(.*)" | string replace -r "^branch refs/heads/" "")'
complete -c wt -s l -d 'List worktrees'
complete -c wt -s h -d 'Show help'
complete -c wt -s v -d 'Show version'

# Subcommands
complete -c wt -n "__fish_use_subcommand" -a "pr" -d 'Check out a GitHub PR'
complete -c wt -n "__fish_use_subcommand" -a "clean" -d 'Remove merged/stale worktrees'
complete -c wt -n "__fish_seen_subcommand_from init" -x -a "bash zsh fish"

# Default: branch names
complete -c wt -n "not __fish_seen_subcommand_from init pr clean; and not __fish_is_switch" -x -a '(git branch --format="%(refname:short)" 2>/dev/null)'
SHELL
      ;;
    *)
      die "unsupported shell: ${shell:-<none>} (use bash, zsh, or fish)"
      ;;
  esac
}

# --- main -------------------------------------------------------------------

main() {
  local mode=""
  local branch=""
  local start_point=""
  local OPTIND

  # Handle subcommands before getopts
  case "${1:-}" in
    init)
      shift
      shell_init "${1:-}"
      return 0
      ;;
    pr)
      shift
      ensure_git
      pr_worktree "${1:-}"
      return 0
      ;;
    clean)
      shift
      ensure_git
      clean_worktrees "$@"
      return 0
      ;;
  esac

  while getopts ":d:lhv" opt; do
    case "$opt" in
      d) mode="delete"; branch="$OPTARG" ;;
      l) mode="list" ;;
      h) usage ;;
      v) echo "$PROG $VERSION"; exit 0 ;;
      :) die "option -$OPTARG requires an argument" ;;
      *) die "unknown option: -$OPTARG" ;;
    esac
  done
  shift $((OPTIND - 1))

  ensure_git

  # Default mode: if a positional arg is given, go to that branch; otherwise fzf
  if [ -z "$mode" ]; then
    if [ $# -gt 0 ]; then
      mode="goto"
      branch="$1"
      start_point="${2:-}"
    else
      mode="pick"
    fi
  fi

  case "$mode" in
    pick)
      pick_worktree ""
      ;;
    goto)
      goto_worktree "$branch" "$start_point"
      ;;
    delete)
      remove_worktree "$branch"
      ;;
    list)
      annotate_worktrees | while IFS=$'\t' read -r flags branch path ab; do
        printf '%s %-30s %s\n' "$flags" "$branch$ab" "$path"
      done
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
